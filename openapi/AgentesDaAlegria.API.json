{
  "openapi": "3.1.1",
  "info": {
    "title": "Agentes da Alegria API",
    "description": "API de gestão de voluntários e eventos para ONGs.",
    "version": "v1"
  },
  "paths": {
    "/api/auth/registrar": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "AU-01 Cadastro de voluntário",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistroDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistroDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegistroDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "AU-02 Login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "AU-02 Renovar access token (refresh)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshTokenDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenResponseDto"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/esqueci-senha": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "AU-03 Solicitar redefinição de senha",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EsqueciSenhaDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/EsqueciSenhaDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/EsqueciSenhaDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/redefinir-senha": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "AU-03 Redefinir senha com token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RedefinirSenhaDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RedefinirSenhaDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RedefinirSenhaDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/auth/criar-voluntario": {
      "post": {
        "tags": [
          "Auth"
        ],
        "summary": "AU-04 Admin cria voluntário",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistroDto"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistroDto"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegistroDto"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        },
        "security": [
          { }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "EsqueciSenhaDto": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          }
        }
      },
      "LoginDto": {
        "required": [
          "email",
          "senha"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "senha": {
            "type": "string"
          }
        }
      },
      "RedefinirSenhaDto": {
        "required": [
          "email",
          "token",
          "novaSenha"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "novaSenha": {
            "type": "string"
          }
        }
      },
      "RefreshTokenDto": {
        "required": [
          "accessToken",
          "refreshToken"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "RegistroDto": {
        "required": [
          "nomeCompleto",
          "apelido",
          "dataNascimento",
          "email",
          "senha",
          "telefone",
          "instagram",
          "endereco"
        ],
        "type": "object",
        "properties": {
          "nomeCompleto": {
            "type": "string"
          },
          "apelido": {
            "type": "string"
          },
          "dataNascimento": {
            "type": "string",
            "format": "date"
          },
          "email": {
            "type": "string"
          },
          "senha": {
            "type": "string"
          },
          "telefone": {
            "type": "string"
          },
          "instagram": {
            "type": [
              "null",
              "string"
            ]
          },
          "endereco": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "TokenResponseDto": {
        "required": [
          "accessToken",
          "refreshToken",
          "expiracao"
        ],
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiracao": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    },
    "securitySchemes": {
      "Bearer": {
        "type": "http",
        "description": "Informe o access token JWT obtido no endpoint /api/auth/login.",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },
  "tags": [
    {
      "name": "Auth"
    }
  ]
}